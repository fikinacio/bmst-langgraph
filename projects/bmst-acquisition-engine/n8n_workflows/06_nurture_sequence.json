    },
    "Airtable — Update Company": {
      "main": [[{ "node": "Split in Batches", "type": "main", "index": 0 }]]
    },
    "Error Trigger": {
      "main": [[{ "node": "Forward to Workflow 05", "type": "main", "index": 0 }]]
    }
  },

  "active": false,
  "settings": { "executionOrder": "v1" },
  "id": "wf-bmst-06-nurture-sequence"
}
