    },
    "Set — Parse Bot Response": {
      "main": [[{ "node": "HTTP — Evolution API Send", "type": "main", "index": 0 }]]
    },
    "HTTP — Evolution API Send": {
      "main": [[{ "node": "Airtable — Log Outbound", "type": "main", "index": 0 }]]
    },
    "Airtable — Log Outbound": {
      "main": [[{ "node": "HTTP — Get Inbound Replies", "type": "main", "index": 0 }]]
    },
    "HTTP — Get Inbound Replies": {
