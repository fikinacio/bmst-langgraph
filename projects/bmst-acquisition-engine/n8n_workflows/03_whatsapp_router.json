      "name": "Webhook — Evolution API",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300]
    },

    {
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "f-event-type",
              "name": "event_type",
              "value": "={{ $json.body?.event ?? $json.event ?? '' }}",
              "type": "string"
            },
            {
              "id": "f-remote-jid",
              "name": "raw_remote_jid",
              "value": "={{ $json.body?.data?.key?.remoteJid ?? $json.data?.key?.remoteJid ?? '' }}",
              "type": "string"
            },
            {
              "id": "f-from-me",
              "name": "from_me",
              "value": "={{ $json.body?.data?.key?.fromMe ?? $json.data?.key?.fromMe ?? false }}",
              "type": "boolean"
            },
            {
              "id": "f-message-type",
              "name": "message_type",
              "value": "={{ $json.body?.data?.messageType ?? $json.data?.messageType ?? '' }}",
              "type": "string"
            },
            {
              "id": "f-push-name",
              "name": "push_name",
              "value": "={{ $json.body?.data?.pushName ?? $json.data?.pushName ?? '' }}",
              "type": "string"
            },
            {
              "id": "f-message-obj",
              "name": "raw_message_obj",
              "value": "={{ $json.body?.data?.message ?? $json.data?.message ?? {} }}",
              "type": "object"
            }
          ]
        },
        "options": {}
      },
      "id": "a3000001-0003-0003-0003-000000000002",
      "name": "Set — Extract Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [480, 300]
    },

    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// Skip non-message events (connection updates, status changes, etc.)\nconst eventType = item.event_type || '';\nif (eventType && eventType !== 'messages.upsert') {\n  return [];\n}\n\n// Skip messages the bot sent itself\nif (item.from_me === true) {\n  return [];\n}\n\n// Extract readable text from conversation, extended text, or image caption\nconst msgObj = item.raw_message_obj || {};\nconst messageText = (\n  msgObj.conversation ||\n  (msgObj.extendedTextMessage && msgObj.extendedTextMessage.text) ||\n  (msgObj.imageMessage && msgObj.imageMessage.caption) ||\n  ''\n).trim();\n\n// Skip non-text messages (audio, video, stickers, reactions)\nif (!messageText) {\n  return [];\n}\n\n// --- Normalise remoteJid ---\n// Strip @lid (experimental JID format) and replace with standard domain\nlet jid = (item.raw_remote_jid || '').trim();\njid = jid.replace(/@lid$/, '@s.whatsapp.net');\n// Strip multi-device suffix, e.g. 244912345678:5@s.whatsapp.net\njid = jid.replace(/:\\d+@s\\.whatsapp\\.net$/, '@s.whatsapp.net');\n// Add domain if somehow missing\nif (!jid.includes('@')) {\n  jid = jid + '@s.whatsapp.net';\n}\n\n// Numeric-only phone number for Airtable lookup (no plus sign, no spaces)\nconst whatsapp_number = jid.split('@')[0].replace(/\\D/g, '');\n\nreturn [{\n  json: {\n    event_type: item.event_type,\n    push_name: item.push_name,\n    raw_remote_jid: item.raw_remote_jid,\n    remote_jid: jid,\n    whatsapp_number: whatsapp_number,\n    message_text: messageText,\n    message_type: item.message_type\n  }\n}];"
      },
      "id": "a3000001-0003-0003-0003-000000000003",
      "name": "Code — Normalise remoteJid",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 300]
    },

    {
      "parameters": {
        "operation": "list",
        "base": {
          "__rl": true,
          "value": "={{ $vars.AIRTABLE_BASE_ID }}",
          "mode": "id"
        },
        "table": {
          "__rl": true,
          "value": "companies",
          "mode": "name"
        },
        "filterByFormula": "={{ \"{whatsapp_number}='\" + $json.whatsapp_number + \"'\" }}",
        "returnAll": false,
        "limit": 1,
        "options": {
          "fields": [
            "company_name",
            "contact_name",
            "whatsapp_number",
            "sector",
            "state",
            "conversation_stage",
            "team_size",
            "main_challenge",
            "priority_process",
            "urgency_level",
            "qualification_score"
          ]
        }
      },
      "id": "a3000001-0003-0003-0003-000000000004",
      "name": "Airtable — Lookup Company",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2,
      "position": [960, 300],
      "credentials": {
        "airtableTokenApi": { "id": "airtable-cred", "name": "Airtable (BMST)" }
      }
    },

    {
