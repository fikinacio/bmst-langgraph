            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-record-found",
              "leftValue": "={{ ($json.records?.length ?? 0) > 0 || ($json.id !== undefined && $json.id !== '') }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            },
            {
              "id": "cond-active-state",
              "leftValue": "={{ (['prospect','contacted','lead','qualification'].includes($json.records?.[0]?.fields?.state ?? $json.fields?.state ?? '')) || (($json.records?.[0]?.fields?.state ?? $json.fields?.state ?? '') === 'nurture' && ($json.records?.[0]?.fields?.conversation_stage ?? $json.fields?.conversation_stage ?? '') === 'requalify') }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a3000001-0003-0003-0003-000000000005",
      "name": "IF — Active State?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1200, 300]
    },

