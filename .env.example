# =============================================================================
# bmst-agents — variáveis de ambiente
# Copiar para .env e preencher antes de arrancar os containers
# NUNCA commitar o ficheiro .env
# =============================================================================

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── API INTERNA ───────────────────────────────────────────────────────────────
# Chave partilhada entre n8n → bmst-agents (header X-Api-Key)
# Gerar com: openssl rand -hex 32
BMST_API_KEY=gerar-com-openssl-rand-hex-32

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Em Docker: redis://redis:6379
# Local:     redis://localhost:6379
REDIS_URL=redis://redis:6379

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Obter em: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GOOGLE SHEETS ─────────────────────────────────────────────────────────────
# ID do Google Sheet partilhado com o PROSPECTOR
# Ex: https://docs.google.com/spreadsheets/d/SHEET_ID_AQUI/edit
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
# Caminho para o ficheiro JSON da service account (montado como volume)
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/google-service-account.json

# ── EVOLUTION API (WhatsApp) ──────────────────────────────────────────────────
# Em Docker na mesma rede: http://evolution-api:8080
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=chave-do-painel-evolution
# Nome da instância WhatsApp configurada no Evolution
EVOLUTION_INSTANCE=bmst

# ── TELEGRAM ──────────────────────────────────────────────────────────────────
# Criar bot em: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# Chat ID do fundador — obter via: https://t.me/userinfobot
TELEGRAM_CHAT_ID=987654321

# ── LANGFUSE (observabilidade) ────────────────────────────────────────────────
# Obter em: https://cloud.langfuse.com → Settings → API Keys
# Ou self-hosted: http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── CONFIGURAÇÕES DA APP ──────────────────────────────────────────────────────
# Ambiente: development | production
APP_ENV=development
# Máximo de mensagens WhatsApp por dia (regra anti-spam)
HUNTER_MAX_MESSAGES_PER_DAY=20
# Espera entre mensagens WhatsApp em segundos
HUNTER_DELAY_BETWEEN_MESSAGES=90
