# =============================================================================
# bmst-social-agents — Fly.io secrets reference
#
# Set these with:
#   fly secrets set KEY=value KEY2=value2 ...
#
# Or import from a file:
#   fly secrets import < .fly/secrets.example   (after filling in real values)
#
# NEVER commit real values. This file contains only placeholders.
# =============================================================================

# ── REQUIRED — app will not start without these ───────────────────────────────

# Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Internal shared key between n8n and the API (X-API-Key header).
# Generate with: openssl rand -hex 32
BMST_API_KEY=REPLACE_WITH_RANDOM_HEX_32

# Supabase project URL and service-role key (app.supabase.com → Settings → API)
SUPABASE_URL=https://REPLACE.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# Evolution API (WhatsApp gateway)
EVOLUTION_API_URL=https://your-evolution-api.example.com
EVOLUTION_API_KEY=REPLACE_ME
EVOLUTION_INSTANCE=biscaplus

# WhatsApp approver phone number — E.164 format: + followed by 7–15 digits.
# Example Swiss number: +41795748225
REVISOR_APPROVER_PHONE=+REPLACE_COUNTRY_CODE_AND_NUMBER

# ── REDIS — set automatically by Fly.io after "fly redis attach" ──────────────
# Do NOT set this manually. Running "fly redis attach <redis-name>" will
# create this secret with the correct rediss:// (TLS) URL.
#
# REDIS_URL=rediss://:password@hostname:port   ← filled by fly redis attach

# ── APP SETTINGS ──────────────────────────────────────────────────────────────

APP_ENV=production
LOG_LEVEL=INFO

# ── OPTIONAL — agents degrade gracefully when these are absent ────────────────

# Tavily (SCOUT news search — app.tavily.com)
TAVILY_API_KEY=tvly-REPLACE_ME

# GPTZero AI-content detector (app.gptzero.me) — REVISOR falls back to Claude
GPTZERO_API_KEY=REPLACE_ME

# ── WRITER / REVISOR model config (defaults shown) ────────────────────────────

WRITER_MODEL=claude-sonnet-4-6
WRITER_MAX_TOKENS=1024
WRITER_LANGUAGE=pt
# REVISOR_MODEL=           ← leave unset to reuse WRITER_MODEL

# ── CAROUSEL — Canva MCP (canva.com/developers) ───────────────────────────────

CANVA_API_TOKEN=REPLACE_ME
CANVA_BRAND_KIT_ID=REPLACE_ME
CANVA_TEMPLATE_ID=REPLACE_ME
CAROUSEL_DEFAULT_SLIDES=5

# ── PUBLISHER — LinkedIn (linkedin.com/developers/apps) ──────────────────────

LINKEDIN_CLIENT_ID=REPLACE_ME
LINKEDIN_CLIENT_SECRET=REPLACE_ME
LINKEDIN_ACCESS_TOKEN=REPLACE_ME
LINKEDIN_ORG_URN=urn:li:organization:REPLACE_ME

# ── PUBLISHER — Meta (developers.facebook.com) ───────────────────────────────

INSTAGRAM_ACCESS_TOKEN=REPLACE_ME
INSTAGRAM_ACCOUNT_ID=REPLACE_ME
FACEBOOK_PAGE_ID=REPLACE_ME

# ── SCHEDULER ─────────────────────────────────────────────────────────────────

# Cron expression (UTC). Default: Mon–Fri 07:00 UTC = 08:00 Luanda.
SCHEDULER_CRON=0 7 * * 1-5
SCHEDULER_TIMEZONE=Africa/Luanda
REVISOR_APPROVAL_TIMEOUT_SECONDS=3600

# ── OBSERVABILITY — Langfuse (optional, cloud.langfuse.com) ──────────────────

# LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
# LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── SCOUT tuning (optional, defaults shown) ───────────────────────────────────

# SCOUT_RSS_FEEDS=https://feeds.bbci.co.uk/news/technology/rss.xml
# SCOUT_LOOKBACK_DAYS=1
# SCOUT_MAX_ARTICLES=10
